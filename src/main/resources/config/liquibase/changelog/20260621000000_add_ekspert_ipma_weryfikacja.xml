<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260621000000-1" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="konkurs_ekspertipma"/>
            </not>
        </preConditions>
        <createTable tableName="konkurs_ekspertipma">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="imie" type="varchar(255)"/>
            <column name="nazwisko" type="varchar(255)"/>
            <column name="data_szkolenia" type="date"/>
            <column name="wymagajace_weryfikacji" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="asesor_id" type="bigint"/>
        </createTable>
    </changeSet>

    <changeSet id="20260621000000-2" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="konkurs_ekspertipma"/>
            <not>
                <columnExists tableName="konkurs_ekspertipma" columnName="wymagajace_weryfikacji"/>
            </not>
        </preConditions>
        <addColumn tableName="konkurs_ekspertipma">
            <column name="wymagajace_weryfikacji" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
